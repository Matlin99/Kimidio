# Kimi API
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Claude API (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# MiniMax API (海螺 — new accounts get free credit)
MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_MODEL=MiniMax-Text-01

# TTS: Microsoft Edge TTS (free, no key required)
# Optionally override the voice. Common picks:
#   en-US-AvaMultilingualNeural  (default, handles en+mixed)
#   zh-CN-XiaoxiaoMultilingualNeural
#   zh-CN-YunxiNeural
# TTS_VOICE=en-US-AvaMultilingualNeural

# OpenWeather (Optional - for weather-aware recommendations)
OPENWEATHER_KEY=your_openweather_key_here

# Server Port (dev only — Tauri bundle uses random port via PORT=0)
PORT=8080
